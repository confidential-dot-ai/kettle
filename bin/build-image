#!/bin/bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

FORCE=0
for arg in "$@"; do
  case "$arg" in
    -f|--force) FORCE=1 ;;
    *)
      echo "unknown argument: $arg" >&2
      echo "usage: $(basename "$0") [-f|--force]" >&2
      exit 1
      ;;
  esac
done

BIN="$REPO_ROOT/target/reproducible/kettle-server"

if [[ ! -f "$BIN" || $FORCE -eq 1 ]]; then
  bin/build-reproducible
fi

if [[ ! -f "$BIN" ]]; then
  echo "expected $BIN to exist after bin/build-reproducible" >&2
  exit 1
fi

if [[ $FORCE -eq 1 ]]; then
  rm -rf "$REPO_ROOT/target/steep"
fi

# set up reproducible kettle-server for the image
mkdir -p "$REPO_ROOT/target/steep/mkosi.extra/usr/local/bin"
cp "$BIN" "$REPO_ROOT/target/steep/mkosi.extra/usr/local/bin"

# download the nix installer to be run later
(
    mkdir -p "$REPO_ROOT/target/steep/mkosi.extra/opt"
    cd "$REPO_ROOT/target/steep/mkosi.extra/opt"
    export VERSION=2.28.0
    export SYSTEM=x86_64-linux
    test -d nix-$VERSION-$SYSTEM || (
        curl -LO https://releases.nixos.org/nix/nix-$VERSION/nix-$VERSION-$SYSTEM.tar.xz
        tar xf nix-$VERSION-$SYSTEM.tar.xz
        rm -rf nix-$VERSION-$SYSTEM.tar.xz
    )
)

# set up the cloud-init user-data file
OUT="$REPO_ROOT/target/steep/user-data.yml"

read -r -d '' UNIT <<'EOF' || true
[Unit]
Description=Kettle build server
After=network-online.target
Wants=network-online.target

[Service]
ExecStart=/usr/local/bin/kettle-server
Restart=no
User=kettle
Group=kettle
NoNewPrivileges=yes
CacheDirectory=kettle-server
Environment=CARGO_HOME=/var/cache/kettle-server/cargo
SupplementaryGroups=sev-guest

[Install]
WantedBy=multi-user.target
EOF

{
  echo "#cloud-config"
  echo "users:"
  echo "  - name: kettle"
  echo "    groups: [sev-guest]"
  echo "groups:"
  echo "  - sev-guest"
  echo "write_files:"
  echo "  - path: /etc/systemd/system/kettle-server.service"
  echo "    permissions: '0644'"
  echo "    owner: root:root"
  echo "    content: |"
  while IFS= read -r line; do
    echo "      $line"
  done <<< "$UNIT"
  echo "  - path: /etc/udev/rules.d/99-sev-guest.rules"
  echo "    permissions: '0644'"
  echo "    owner: root:root"
  echo "    content: |"
  echo "      KERNEL==\"sev-guest\", GROUP=\"sev-guest\", MODE=\"0660\""
  echo "runcmd:"
  # The kernel creates /dev/sev-guest at boot, before the rule above lands;
  # reload and re-trigger so the rule applies before the server starts.
  echo "  - udevadm control --reload-rules"
  echo "  - udevadm trigger --name-match=/dev/sev-guest"
  echo "  - systemctl enable --now kettle-server.service"
  echo "  - bash -c 'cd /opt/nix*; ./install --yes'"
} > "$OUT"

# run steep to build the image
(
    cd ~/steep
    bin/steep build "$REPO_ROOT/target/image" \
      --smp 10 --memory 20G \
      --extra $REPO_ROOT/target/steep/mkosi.extra \
      --cloud-init $REPO_ROOT/target/steep/user-data.yml \
      --package git,curl,ca-certificates,build-essential,cargo,tpm2-tss \
      --console
)

echo "./target/steep contains a reproducible build of kettle-server and cloud-init user-data."
echo "./target/image contains an image, including IGVM measurements, to run attested builds in CVMs."
echo
echo "To use the image, run:"
echo "  bin/kettle-orchestrator target/image"
